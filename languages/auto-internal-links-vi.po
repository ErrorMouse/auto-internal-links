#. Plugin Name of the plugin
msgid "Auto Internal Links"
msgstr "Auto Internal Links"

#. Description of the plugin
msgid "Automatically find keywords matching post titles and add internal links."
msgstr "Tự động tìm từ khóa khớp với tiêu đề bài viết và thêm liên kết nội bộ."

#: auto-internal-links.php:171
msgid "Auto Links Statistics"
msgstr "Thống kê Liên kết"

#: auto-internal-links.php:172
msgid "Auto Links"
msgstr "Liên kết Tự động"

#: auto-internal-links.php:180 auto-internal-links.php:181
msgid "Statistics"
msgstr "Thống kê"

#: auto-internal-links.php:188 auto-internal-links.php:189
msgid "Settings"
msgstr "Cài đặt"

#: auto-internal-links.php:204
msgid "General Settings"
msgstr "Cài đặt Chung"

#: auto-internal-links.php:210
msgid "Apply to post types"
msgstr "Áp dụng cho các loại bài viết"

#: auto-internal-links.php:211
msgid "Exclude posts (ID)"
msgstr "Loại trừ bài viết (ID)"

#: auto-internal-links.php:212
msgid "Minimum title length"
msgstr "Độ dài tiêu đề tối thiểu"

#: auto-internal-links.php:213
msgid "Case sensitive"
msgstr "Phân biệt chữ hoa/thường"

#: auto-internal-links.php:258
msgid "Enter post IDs, separated by commas (e.g., 1, 2, 3)."
msgstr "Nhập ID các bài viết, cách nhau bằng dấu phẩy (VD: 1, 2, 3)."

#: auto-internal-links.php:267
msgid "characters"
msgstr "ký tự"

#: auto-internal-links.php:270
msgid "Shorter titles will not be used as keywords."
msgstr "Các tiêu đề ngắn hơn sẽ không được sử dụng làm từ khóa."

#: auto-internal-links.php:279
msgid "Enable to only add links when the case exactly matches the title."
msgstr "Bật để chỉ thêm liên kết khi từ khóa khớp chính xác chữ hoa/chữ thường với tiêu đề."

#: auto-internal-links.php:306
msgid "Security check failed. Please refresh the page and try again."
msgstr "Kiểm tra bảo mật thất bại. Vui lòng tải lại trang và thử lại."

#: auto-internal-links.php:321
msgid "Every 5 Minutes"
msgstr "Mỗi 5 phút"

#: auto-internal-links.php:446
msgid "Donate to support this plugin"
msgstr "Quyên góp ủng hộ plugin này"

#: auto-internal-links.php:447
msgid "Donate"
msgstr "Quyên góp"

#: settings.php:9
msgid "Auto Internal Links Settings"
msgstr "Cài đặt Auto Internal Links"

#: settings.php:10
msgid "Configure options for automatically adding internal links."
msgstr "Cấu hình các tùy chọn để tự động thêm liên kết nội bộ."

#: statistics.php:15
msgid "Auto Internal Links Statistics"
msgstr "Thống kê Auto Internal Links"

#: statistics.php:18
msgid "Re-scan Data"
msgstr "Quét lại Dữ liệu"

#: statistics.php:20
msgid "Scanning in progress..."
msgstr "Đang tiến hành quét..."

#. translators: %d: number of scanned articles
#: statistics.php:31
msgid "<strong>The system is scanning the data...</strong> Approximately %d articles have been scanned. <br>Please reload the page after a few minutes to see the results when complete."
msgstr "<strong>Hệ thống đang quét dữ liệu...</strong> Đã phân tích được khoảng %d bài viết. <br>Vui lòng tải lại trang sau ít phút để xem kết quả khi hoàn tất."

#: statistics.php:39
msgid "The statistics table lists the Titles (Keywords) that have been automatically linked to other posts. Data is compiled via background scan."
msgstr "Bảng thống kê liệt kê các Tiêu đề (Từ khóa) đã được tự động liên kết đến các bài viết khác. Dữ liệu được tổng hợp thông qua tiến trình quét ngầm."

#: statistics.php:44
msgid "Title / Keyword (Linked)"
msgstr "Tiêu đề / Từ khóa (Được liên kết)"

#: statistics.php:45
msgid "Number of linked posts"
msgstr "Số bài viết được liên kết"

#: statistics.php:51
msgid "No internal link statistics data available. Click Re-scan Data to start generating."
msgstr "Chưa có dữ liệu thống kê. Nhấp vào Quét lại Dữ liệu để bắt đầu phân tích."

#: statistics.php:55
msgid "Scanning in progress... Data will appear here once the scan is complete."
msgstr "Đang tiến hành quét... Dữ liệu sẽ xuất hiện ở đây sau khi quá trình quét hoàn tất."

